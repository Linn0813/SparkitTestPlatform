# 复制为 backend/.env 后修改
#   cp .env.example backend/.env
#
# 数据库：与部署环境共用同一 MySQL（Docker 默认用户 sparkit / 密码 sparkit / 库 sparkit）
#
# A) 在部署机本机跑前后端：
#    DATABASE_URL=mysql+aiomysql://sparkit:sparkit@127.0.0.1:3307/sparkit
#
# B) 在自己电脑开发、连部署机上的库（内网优先，外网回退；启动时自动探测）：
#    ./dev/link-dev-to-deploy.sh <内网IP> [外网/Tailscale_IP]
#    例: ./dev/link-dev-to-deploy.sh 172.19.3.69 100.122.228.39
#    本机不要执行 dev/start.sh，避免连到两套库
#    DATABASE_HOST_LAN=172.19.3.69
#    DATABASE_HOST_WAN=100.122.228.39
#    DATABASE_PORT=3307
#
# C) 在部署机本机跑前后端，并允许 Tailscale 远程访问（在公司 Mac 上执行）：
#    ./dev/configure-deploy-host-env.sh 100.122.228.39
#    ./dev/configure-deploy-host-env.sh 100.122.228.39 172.19.3.69
#    详见 dev/TAILSCALE.md

DATABASE_URL=mysql+aiomysql://sparkit:sparkit@127.0.0.1:3307/sparkit
# 仅 init_database 建库时用（Docker 默认 root/root；与 compose 不一致时请改）
# DATABASE_ADMIN_URL=mysql+aiomysql://root:root@127.0.0.1:3307/mysql
# 可选：连接池
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=1800
# DB_POOL_PRE_PING=true
# DB_CONNECT_TIMEOUT=10

SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# 图片/附件下载链接的 API 根地址（生成 /api/v1/files/raw 签名 URL；默认相对路径经前端代理）
API_PUBLIC_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# MinIO（附件/视频，与 dev/docker-compose.yml 一致）
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sparkit
MINIO_SECURE=false
WECOM_REQUEST_TIMEOUT=5
APP_PUBLIC_URL=http://localhost:5174
# 企微通知 {link} 默认用 APP_PUBLIC_URL；若仍为 localhost，请在项目设置 → 企微通知填写「站点访问地址」
# （局域网：http://172.19.3.69:5174；Tailscale：http://100.122.228.39:5174）
